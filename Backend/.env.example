# ── Core ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/yatrago

# ── JWT (REQUIRED in production, min 32 chars each) ─────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Access and refresh MUST be different values.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
# Optional dedicated pepper for hashing OTPs in Redis (defaults to refresh secret)
OTP_PEPPER=

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── HTTP / proxy / WAF ──────────────────────────────────────────
# Trust X-Forwarded-For only from known proxies (IP-spoofing protection):
#   0/unset  = direct exposure, never trust the header
#   1        = one proxy hop (single nginx / ALB)
#   N        = N hops
#   CSV      = explicit proxy IPs/CIDRs (Cloudflare / AWS WAF ranges),
#              e.g. 173.245.48.0/20,103.21.244.0/22
TRUST_PROXY=0
# Rate-limit overrides (defaults are safe for production; raise only for local
# e2e suites). THROTTLE_LIMIT = global req/min; OTP_THROTTLE_LIMIT = /auth/send-otp
# per min; VERIFY_THROTTLE_LIMIT = /auth/verify-otp per min.
THROTTLE_LIMIT=100
OTP_THROTTLE_LIMIT=5
VERIFY_THROTTLE_LIMIT=10
# Comma-separated browser origins allowed by CORS (admin console URLs).
CORS_ORIGINS=http://localhost:5173
# Swagger is always on outside production; set true to expose it in production.
SWAGGER_ENABLED=false

# ── DEV-ONLY wallet bypass (TESTING ONLY) ───────────────────────
# When true, posting a ride skips the minimum-wallet-balance check so you can
# create rides without topping up. Does NOT credit money or touch balances,
# transactions, top-ups, or eSewa — it only skips the balance assertion.
# IGNORED in production (forced off when NODE_ENV=production). Leave false.
DEV_BYPASS_WALLET_CHECK=false

# ── SMS (Sparrow) — REQUIRED in production ──────────────────────
SPARROW_TOKEN=
SPARROW_FROM=YatraGo

# ── Maps ────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── eSewa payment gateway (wallet top-ups) ──────────────────────
# ePay-v2. Values below are eSewa's PUBLIC SANDBOX credentials — safe for
# testing only. Replace with LIVE credentials (and live *_URL endpoints)
# for production; ESEWA_SECRET_KEY is REQUIRED in production (fail secure).
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form
ESEWA_STATUS_URL=https://rc-epay.esewa.com.np/api/epay/transaction/status/
ESEWA_PRODUCT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
# Absolute https URLs eSewa redirects the in-app WebView to. The backend does
# NOT trust these for crediting — it re-verifies server-to-server. They only
# let the app detect success/cancel and close the WebView.
ESEWA_SUCCESS_URL=https://yatrago.app/payments/esewa/success
ESEWA_FAILURE_URL=https://yatrago.app/payments/esewa/failure
# A top-up intent must complete within this many minutes, else it expires.
ESEWA_INTENT_TTL_MINUTES=30
# Self-service top-up amount limits (NPR).
ESEWA_MIN_TOPUP=100
ESEWA_MAX_TOPUP=100000

# ── Cloudflare R2 (uploads) ─────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# HMAC key for signed KYC file URLs (defaults to JWT_REFRESH_SECRET if unset)
FILE_SIGNING_SECRET=

# AES-256-GCM key for PII field encryption (defaults to JWT_REFRESH_SECRET)
ENCRYPTION_KEY=
# Comma-separated IPs allowed to hit /admin (empty = disabled)
ADMIN_IP_ALLOWLIST=
# Wallet credits above this NPR amount require a super_admin
ADMIN_CREDIT_SUPER_THRESHOLD=10000

# ── Admin session policy ────────────────────────────────────────
# Admins must have TOTP enrolled before /admin/* works.
# Default: enforced in production, off elsewhere. Set explicitly to override.
ADMIN_MFA_REQUIRED=
# Idle admin sessions die after this many seconds without a token refresh.
ADMIN_INACTIVITY_TIMEOUT_SECONDS=3600

# ── Managed secrets (production) ────────────────────────────────
# aws | gcp | azure — hydrates process.env from the secret store at boot,
# BEFORE any config is read. Install the matching SDK:
#   aws:   npm i @aws-sdk/client-secrets-manager
#   gcp:   npm i @google-cloud/secret-manager
#   azure: npm i @azure/keyvault-secrets @azure/identity
# The secret must contain a JSON object of KEY=value pairs.
SECRETS_PROVIDER=
SECRETS_NAME=
# Azure only:
AZURE_KEY_VAULT_URL=

# ── Fraud / anomaly detection ───────────────────────────────────
# Path to a MaxMind GeoLite2-City.mmdb (free with a MaxMind account).
# Enables impossible-travel + country-change login detection.
GEOIP_DB_PATH=
# Fraud-score logins from Tor exit nodes (list auto-refreshed 12-hourly).
# Default: on in production, off elsewhere.
TOR_CHECK_ENABLED=
# Google Safe Browsing v4 key for chat URL reputation (optional).
SAFE_BROWSING_API_KEY=

# ── Monitoring / alerting ───────────────────────────────────────
# Bearer token required to scrape GET /api/v1/metrics (empty = endpoint off).
METRICS_TOKEN=
# Sentry DSN for 5xx error tracking (optional).
SENTRY_DSN=
# Slack-compatible webhook for security alerts: OTP attack spikes,
# refresh-token theft, fraud surges (optional).
SECURITY_ALERT_WEBHOOK=
